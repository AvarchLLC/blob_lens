# ── Legacy api_v1 services (whale/RWA/OFAC/AI analyst) ──────────────────────
ALCHEMY_KEY=YOUR_API_KEY_HERE

# ── PostgreSQL (api_v1 + web frontend for non-blob data) ────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/blob_lens

# ── ClickHouse (ExEx + backfill + web frontend for blob/ETH data) ───────────
CLICKHOUSE_URL=http://ba-data:8123
CLICKHOUSE_DB=blob_lens
CLICKHOUSE_USER=blob_lens
CLICKHOUSE_PASSWORD=changeme

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── AI analyst (optional — if unset, seeds mock insights) ───────────────────
# CLAUDE_API_KEY=
